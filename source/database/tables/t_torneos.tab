create table T_TORNEOS
(
  id_torneo                VARCHAR2(12) not null,
  id_division              VARCHAR2(3),
  temporada                NUMBER(4),
  titulo                   VARCHAR2(50),
  denominacion_oficial     VARCHAR2(100),
  saldo_inicial            NUMBER(18,3),
  actual                   VARCHAR2(1) default 'N' not null,
  titulo_alternativo       VARCHAR2(50),
  prueba                   VARCHAR2(1) default 'N',
  tipo                     VARCHAR2(1) default 'L',
  importado                VARCHAR2(1) default 'N',
  fecha_ultima_importacion TIMESTAMP(0) WITH TIME ZONE,
  id_importacion           NUMBER(15),
  desc_importacion         VARCHAR2(200),
  incluir_alineaciones     VARCHAR2(1) default 'N' not null,
  incluir_incidencias      VARCHAR2(1) default 'N' not null
)
;
comment on table T_TORNEOS
  is 'Torneos';
comment on column T_TORNEOS.actual
  is 'żEs torneo actual?';
comment on column T_TORNEOS.prueba
  is 'żEs torneo de prueba?';
comment on column T_TORNEOS.tipo
  is 'Tipo de torneo. (L-Liga, C-Copa)';
comment on column T_TORNEOS.importado
  is 'żEl torneo ingresa al proceso de importación? (S/N)';
comment on column T_TORNEOS.fecha_ultima_importacion
  is 'Fecha de la última importación.';
comment on column T_TORNEOS.id_importacion
  is 'Identificador del torneo importado.';
comment on column T_TORNEOS.desc_importacion
  is 'Descripción del torneo importado.';
comment on column T_TORNEOS.incluir_alineaciones
  is 'żEl torneo incluye alineaciones del partido en el proceso de importación? (S/N)';
comment on column T_TORNEOS.incluir_incidencias
  is 'żEl torneo incluye incidencias del partido en el proceso de importación? (S/N)';
alter table T_TORNEOS
  add constraint PK_TORNEOS primary key (ID_TORNEO);
alter table T_TORNEOS
  add constraint FK_TORNEOS_DIVISIONES foreign key (ID_DIVISION)
  references T_DIVISIONES (ID_DIVISION);
